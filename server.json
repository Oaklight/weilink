{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-10-17/server.schema.json",
  "name": "io.github.oaklight/weilink",
  "title": "WeiLink",
  "description": "WeChat bot SDK for AI agents — send/receive messages, media, and session management",
  "version": "0.3.0b2",
  "repository": {
    "url": "https://github.com/Oaklight/weilink",
    "source": "github"
  },
  "websiteUrl": "https://weilink.readthedocs.io",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "weilink",
      "version": "0.3.0b2",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "valueHint": "extras",
          "value": "weilink[mcp]"
        }
      ]
    }
  ]
}
